# Printify API Configuration
PRINTIFY_API_TOKEN=your_printify_api_token_here
NEXT_PUBLIC_PRINTIFY_SHOP_ID=your_shop_id_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-site-url.vercel.app

# Image optimization
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true

