# Printify API Configuration
PRINTIFY_API_TOKEN=your_printify_api_token_here

# Make the token available to the client (use a restricted token for client-side)
NEXT_PUBLIC_PRINTIFY_API_TOKEN=${PRINTIFY_API_TOKEN}

# Printify Shop Configuration
NEXT_PUBLIC_PRINTIFY_SHOP_ID=204284

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Analytics Configuration
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id 