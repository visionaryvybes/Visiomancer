# Printify API credentials
PRINTIFY_API_KEY=your_printify_api_key_here
PRINTIFY_SHOP_ID=your_printify_shop_id_here

# Next.js environment variables
NEXT_PUBLIC_SITE_URL=https://your-site-url.vercel.app

# Image optimization
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true

# Optional: Analytics (if you add this later)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here 